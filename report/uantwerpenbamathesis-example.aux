\@writefile{lof}{\contentsline {figure}{\numberline {5.2}{\ignorespaces Systeem met 1 annulus rond een symmetrie-as. De annulus heeft een homogene oppervlaktepoollading gelijk aan $\sigma _M$, wat aanleiding geeft tot een magnetisch veld.}}{17}{figure.caption.7}\protected@file@percent }
